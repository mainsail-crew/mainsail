# URL to the Moonraker instance (used by Vite proxy for development)
# When set, Vite proxies /websocket, /server, /printer, /access, /api to this target
# This avoids CORS issues when running the dev server on localhost:8080
MOONRAKER_TARGET=http://printer.local:7125

# hostname or ip from the moonraker instance
# Leave empty for dev with proxy (will use localhost:8080), or set to moonraker IP for direct connection
#VUE_APP_HOSTNAME=printer.local

# port from the moonraker instance
# Leave empty for dev with proxy, or set to 7125 for direct connection
#VUE_APP_PORT=7125

# route_prefix from the moonraker instance
VUE_APP_PATH="/"

# reconnect interval in ms
VUE_APP_RECONNECT_INTERVAL=5000

# where should mainsail read the instances from (moonraker, browser or json)
VUE_APP_INSTANCES_DB="moonraker"

# defaults for multi language tests
VUE_APP_I18N_LOCALE=en
VUE_APP_I18N_FALLBACK_LOCALE=en