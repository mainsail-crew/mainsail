{
    "compilerOptions": {
        "target": "es2020",
        "module": "esnext",
        "strict": true,
        "jsx": "preserve",
        "importHelpers": true,
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "experimentalDecorators": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "types": ["cypress", "vite/client"],
        "paths": {
            "@/*": ["./src/*"],
            "vuex": ["./node_modules/vuex/types/index.d.ts"],
            "unplugin-vue-components/vite": ["./node_modules/unplugin-vue-components/dist/vite.d.ts"],
            "unplugin-vue-components/resolvers": ["./node_modules/unplugin-vue-components/dist/resolvers.d.ts"]
        },
        "lib": ["esnext", "dom", "dom.iterable", "scripthost"],
        "typeRoots": ["./node_modules/@types", "./node_modules/cypress/types", "./node_modules/vuetify/types"]
    },
    "include": [
        "vite.config.ts",
        "src/types/*.d.ts",
        "components.d.ts",
        "src/main.ts",
        "src/*/*.ts",
        "src/**/*.tsx",
        "src/**/*.vue",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "node_modules/vite-plugin-pwa/client.d.ts"
    ],
    "exclude": ["node_modules"]
}
